		flex: 1;
		background-color: #f7efe6;
		padding: 10px 0 12px;
		border-radius: 20px;
		align-items: center;
		margin-right: 8px;
		border-width: 1px;
		border-style: solid;
		border-color: #e3d7ca;
	}

