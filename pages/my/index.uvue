	.summary-item {
		flex: 1;
		min-width: 140px;
		background-color: #fffdf9;
		border-radius: 18px;
		padding: 14px 12px;
		margin-right: 8px;
		margin-bottom: 8px;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

