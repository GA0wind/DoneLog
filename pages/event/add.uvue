<template>
	<scroll-view scroll-y class="container">
		<view class="form">
			<!-- 事件名称 -->
			<view class="form-item">
				<text class="label">事件名称 *</text>
				<input class="input" v-model="eventName" placeholder="请输入事件名称" />
			</view>

			<!-- 标签选择 -->
			<view class="form-item">
				<text class="label">选择标签</text>
				<view class="label-row">
					<view class="tag-selector" @click="showLabelModal">
						<view class="selected-tags">
							<text 
								class="tag" 
								v-for="labelId in selectedLabelIds" 
								:key="labelId"
								:style="{ backgroundColor: getLabelColor(labelId) }"
							>
								{{getLabelName(labelId)}}
							</text>
							<text class="placeholder" v-if="selectedLabelIds.length === 0">请选择标签</text>
						</view>
						<text class="arrow">▼</text>
					</view>
					<button class="mini-add-btn" @click.stop="openAddLabelModal">新增标签</button>
				</view>
			</view>

			<!-- 重复方式选择 -->
			<view class="form-item">
				<text class="label">重复方式</text>
				<radio-group @change="onRepeatTypeChange">
					<label class="radio-item">
						<radio value="interval" :checked="repeatType === 'interval'" />
						<text class="radio-text">按间隔天数</text>
					</label>
					<label class="radio-item">
						<radio value="date" :checked="repeatType === 'date'" />
						<text class="radio-text">自定义下次完成时间</text>
					</label>
					<label class="radio-item">
						<radio value="single" :checked="repeatType === 'single'" />
						<text class="radio-text">不重复</text>
					</label>
				</radio-group>
			</view>

			<!-- 间隔天数 -->
			<view class="form-item" v-if="repeatType === 'interval'">
				<text class="label">间隔天数</text>
				<input 
					class="input" 
					type="number" 
					v-model="intervalDays" 
					placeholder="0 表示明天，1 表示后天" 
				/>
				<text class="field-tip">按“中间空几天”计算：0 表示明天再次需要完成。</text>
			</view>

			<!-- 下次完成时间 -->
			<view class="form-item" v-if="repeatType === 'date'">
				<text class="label">下次完成时间</text>
				<picker mode="date" :value="nextDueDate" @change="onDateChange">
					<view class="picker">
						<text>{{nextDueDate.length > 0 ? nextDueDate : '请选择日期'}}</text>
					</view>
				</picker>
			</view>

			<view class="form-item">
				<text class="label">创建时状态</text>
				<label class="switch-row">
					<switch :checked="isCompletedToday" color="#1F7A72" @change="onCompletedTodayChange" />
					<text class="switch-text">今天已经完成过</text>
				</label>
				<text class="field-tip" v-if="isCompletedToday">保存后会自动生成今天的完成记录；不重复事项会直接终止。</text>
			</view>

			<!-- 备注 -->
			<view class="form-item">
				<text class="label">备注</text>
				<textarea class="textarea" v-model="remark" placeholder="请输入备注（可选）" />
			</view>

			<!-- 保存按钮 -->
			<button class="save-btn" @click="saveEvent">保存</button>
		</view>

		<!-- 标签选择弹窗 -->
		<view class="modal selector-modal" v-if="showLabelSelector" @click="hideLabelModal">
			<view class="modal-content selector-modal-content" @click.stop>
				<text class="modal-title">选择标签</text>
				<scroll-view scroll-y class="selector-body">
					<view
						class="selector-item"
						:class="{ selected: selectedLabelIds.includes(label.id) }"
						v-for="label in labels"
						:key="label.id"
						@click.stop="toggleLabel(label.id)"
					>
						<view class="selector-left">
							<view class="selector-color" :style="{ backgroundColor: label.color }"></view>
							<text class="selector-name">{{label.name}}</text>
						</view>
						<view class="selector-check-wrap">
							<text class="selector-check" :class="{ visible: selectedLabelIds.includes(label.id) }">✓</text>
						</view>
					</view>
				</scroll-view>
				<view class="modal-footer">
					<button class="confirm-btn single-btn" @click.stop="confirmLabels">确定</button>
				</view>
			</view>
		</view>

		<!-- 新增标签弹窗 -->
		<view class="modal add-label-modal" v-if="showAddLabelModal" @click="hideAddLabelModal">
			<view class="modal-content selector-modal-content" @click.stop>
				<text class="modal-title">新增标签</text>
				<view class="modal-body">
					<view class="form-item">
						<text class="label">标签名称</text>
						<input class="input" v-model="newLabelName" placeholder="请输入标签名称" confirm-type="done" @input="clearNewLabelError" @confirm="addNewLabel" />
						<text class="error-tip" v-if="newLabelError">{{newLabelError}}</text>
					</view>
					<view class="form-item">
						<text class="label">标签颜色</text>
						<view class="color-options">
							<view 
								class="color-option" 
								v-for="color in colorOptions" 
								:key="color"
								:class="{ 'selected': newLabelColor === color }"
								:style="{ backgroundColor: color }"
								@click.stop="newLabelColor = color"
							>
								<text v-if="newLabelColor === color" class="color-check-icon">✓</text>
							</view>
						</view>
					</view>
				</view>
				<view class="modal-footer">
					<button class="cancel-btn" @click.stop="hideAddLabelModal">取消</button>
					<button class="confirm-btn" @click.stop="addNewLabel">确定</button>
				</view>
			</view>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
	import { EventManager } from '@/utils/eventManager.uts'
	import { LabelManager } from '@/utils/labelManager.uts'
	import { EventInput, Label } from '@/utils/storage.uts'

	// 响应式数据
	const eventName = ref('')
	const selectedLabelIds = ref<number[]>([])
	const labels = ref<Label[]>([])
	const repeatType = ref<'interval' | 'date' | 'single'>('interval')
	const intervalDays = ref('')
	const nextDueDate = ref('')
	const remark = ref('')
	const isCompletedToday = ref(false)
	const showLabelSelector = ref(false)
	const showAddLabelModal = ref(false)
	const newLabelName = ref('')
	const newLabelError = ref('')
	const newLabelColor = ref('#007AFF')

	// 预设颜色选项
	const colorOptions = [
		'#007AFF', // 蓝色
		'#FF3B30', // 红色
		'#FF9500', // 橙色
		'#FFCC00', // 黄色
		'#4CD964', // 绿色
		'#5AC8FA', // 浅蓝
		'#5856D6', // 紫色
		'#FF2D55', // 粉色
		'#8E8E93', // 灰色
		'#34C759'  // 深绿
	]

	const getDetailObject = (e: UTSJSONObject): UTSJSONObject | null => {
		const detail = e['detail']
		return detail != null ? detail as UTSJSONObject : null
	}

	const getDetailStringValue = (e: UTSJSONObject, key: string): string => {
		const detail = getDetailObject(e)
		if (detail == null) return ''
		const value = detail[key]
		return value != null ? `${value}` : ''
	}

	const getDetailBooleanValue = (e: UTSJSONObject, key: string): boolean => {
		const detail = getDetailObject(e)
		if (detail == null) return false
		const value = detail[key]
		return value === true
	}

	// 加载标签列表
	const loadLabels = () => {
		labels.value = LabelManager.getSortedLabels('event')
	}

	// 切换标签选择
	const toggleLabel = (labelId: number) => {
		const index = selectedLabelIds.value.indexOf(labelId)
		if (index > -1) {
			selectedLabelIds.value.splice(index, 1)
		} else {
			selectedLabelIds.value.push(labelId)
		}
	}

	// 显示标签选择弹窗
	const showLabelModal = () => {
		showLabelSelector.value = true
	}

	// 隐藏标签选择弹窗
	const hideLabelModal = () => {
		showLabelSelector.value = false
	}

	// 确认标签选择
	const confirmLabels = () => {
		hideLabelModal()
	}

	// 显示新增标签弹窗
	const openAddLabelModal = () => {
		newLabelName.value = ''
		newLabelError.value = ''
		newLabelColor.value = '#007AFF'
		showAddLabelModal.value = true
	}

	// 隐藏新增标签弹窗
	const hideAddLabelModal = () => {
		showAddLabelModal.value = false
		newLabelError.value = ''
	}

	const clearNewLabelError = () => {
		if (newLabelError.value.length > 0) {
			newLabelError.value = ''
		}
	}

	// 新增标签
	const addNewLabel = () => {
		const createdName = newLabelName.value.trim()
		if (createdName.length === 0) {
			newLabelError.value = '请输入标签名称'
			uni.showToast({
				title: '请输入标签名称',
				icon: 'none'
			})
			return
		}

		const existingLabel = LabelManager.getLabelByName(createdName, 'event')
		if (existingLabel != null) {
			if (selectedLabelIds.value.includes(existingLabel.id) == false) {
				selectedLabelIds.value.push(existingLabel.id)
			}
			newLabelError.value = '已存在同名标签，已为你选中'
			uni.showToast({
				title: '标签已存在，已选中',
				icon: 'none'
			})
			return
		}

		const success = LabelManager.addLabel(createdName, newLabelColor.value, 'event')
		if (success == true) {
			newLabelName.value = ''
			newLabelError.value = ''
			newLabelColor.value = '#007AFF'
			uni.showToast({
				title: '添加成功',
				icon: 'success'
			})
			loadLabels()
			const created = labels.value.find(item => item.name === createdName)
			if (created != null && selectedLabelIds.value.includes(created.id) == false) {
				selectedLabelIds.value.push(created.id)
			}
			showAddLabelModal.value = false
		} else {
			newLabelError.value = '添加失败，请稍后再试'
			uni.showToast({
				title: '添加失败',
				icon: 'none'
			})
		}
	}

	// 获取标签名称
	const getLabelName = (labelId: number): string => {
		const label = labels.value.find(l => l.id === labelId)
		return label != null ? label.name : ''
	}

	// 获取标签颜色
	const getLabelColor = (labelId: number): string => {
		const label = labels.value.find(l => l.id === labelId)
		return label != null ? label.color : '#007AFF'
	}

	// 重复方式改变
	const onRepeatTypeChange = (e: UTSJSONObject) => {
		const value = getDetailStringValue(e, 'value')
		if (value === 'date' || value === 'single') {
			repeatType.value = value
			return
		}
		repeatType.value = 'interval'
	}

	// 日期改变
	const onDateChange = (e: UTSJSONObject) => {
		nextDueDate.value = getDetailStringValue(e, 'value')
	}

	const onCompletedTodayChange = (e: UTSJSONObject) => {
		isCompletedToday.value = getDetailBooleanValue(e, 'value')
	}

	// 保存事件
	const saveEvent = () => {
		if (eventName.value.trim().length === 0) {
			uni.showToast({
				title: '请输入事件名称',
				icon: 'none'
			})
			return
		}

		if (repeatType.value === 'interval' && intervalDays.value.length === 0) {
			uni.showToast({
				title: '请输入间隔天数',
				icon: 'none'
			})
			return
		}

		if (repeatType.value === 'interval') {
			const interval = parseInt(intervalDays.value)
			if (Number.isNaN(interval) || interval < 0) {
				uni.showToast({
					title: '间隔天数不能小于 0',
					icon: 'none'
				})
				return
			}
		}

		if (repeatType.value === 'date' && nextDueDate.value.length === 0) {
			uni.showToast({
				title: '请选择下次完成时间',
				icon: 'none'
			})
			return
		}

		const event: EventInput = {
			name: eventName.value,
			labelIdList: selectedLabelIds.value.join(','),
			intervalDays: repeatType.value === 'interval' ? parseInt(intervalDays.value) : (repeatType.value === 'single' ? -1 : 0),
			nextDueDate: repeatType.value === 'date' ? new Date(nextDueDate.value).getTime() : 0,
			remark: remark.value,
			isTerminated: false,
			terminatedAt: 0
		}

		const eventId = EventManager.addEventAndGetId(event)
		if (eventId > 0) {
			if (isCompletedToday.value) {
				EventManager.markEventComplete(eventId)
				if (repeatType.value === 'single') {
					EventManager.terminateEvent(eventId)
				}
			}
			uni.showToast({
				title: '保存成功',
				icon: 'success'
			})
			setTimeout(() => {
				uni.navigateBack()
			}, 1500)
		} else {
			uni.showToast({
				title: '保存失败',
				icon: 'none'
			})
		}
	}

	// 页面加载时获取标签
	onLoad(() => {
		LabelManager.initIds()
		loadLabels()
	})
</script>

<style>
	.container {
		padding: 15px;
		background-color: #f4efe7;
		flex: 1;
	}

	.form {
		background-color: #fffaf3;
		border-radius: 24px;
		padding: 18px;
		border-width: 1px;
		border-style: solid;
		border-color: #eadfd2;
		box-shadow: 0 12px 28px rgba(36, 50, 58, 0.06);
	}

