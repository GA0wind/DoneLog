		width: 100%;
		height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 0 15px;
		font-size: 14px;
		color: #24323a;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.tags-container {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.label-row {
		flex-direction: row;
		align-items: flex-start;
	}

	.tag-selector {
		flex: 1;
		margin-right: 10px;
		height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 8px 12px;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
		box-sizing: border-box;
		overflow: hidden;
	}

	.selected-tags {
		flex: 1;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: center;
		height: 26px;
		max-height: 26px;
		overflow: hidden;
	}

	.tag {
		font-size: 12px;
		color: #fff;
		height: 22px;
		line-height: 22px;
		padding: 0 10px;
		border-radius: 999px;
		margin-right: 6px;
		margin-bottom: 0;
	}

	.placeholder {
		font-size: 14px;
		color: #98a2ad;
	}

	.arrow {
		margin-left: 10px;
		font-size: 12px;
		color: #8792a1;
	}

	.mini-add-btn {
		height: 44px;
		line-height: 44px;
		padding: 0 14px;
		border-radius: 16px;
		background-color: #f2ebe2;
		color: #4d5b67;
		font-size: 13px;
		flex-shrink: 0;
	}

	.textarea {
		width: 100%;
		min-height: 100px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 10px 15px;
		font-size: 14px;
		color: #24323a;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.radio-item {
		flex-direction: row;
		align-items: center;
		margin-bottom: 10px;
	}

	.radio-text {
		margin-left: 8px;
		font-size: 14px;
	}

	.switch-row {
		flex-direction: row;
		align-items: center;
	}

	.switch-text {
		margin-left: 10px;
		font-size: 14px;
		color: #24323a;
	}

	.picker {
		height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 0 15px;
		justify-content: center;
		font-size: 14px;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.field-tip {
		font-size: 12px;
		line-height: 1.5;
		color: #8792a1;
		margin-top: 8px;
	}

	.error-tip {
		font-size: 12px;
		line-height: 1.5;
		color: #e07a5f;
		margin-top: 6px;
	}

	.save-btn {
		background: linear-gradient(135deg, #1f7a72, #2a9d8f);
		color: #fff;
		height: 48px;
		line-height: 48px;
		border-radius: 24px;
		font-size: 16px;
		margin-top: 20px;
		box-shadow: 0 14px 24px rgba(31, 122, 114, 0.2);
	}

	/* 弹窗样式 */
	.modal {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		justify-content: center;
		align-items: center;
		z-index: 1000;
	}

	.selector-modal {
		z-index: 1000;
	}

	.add-label-modal {
		z-index: 1010;
	}

	.modal-content {
		background-color: #fffaf3;
		border-radius: 22px;
		width: 88%;
		max-height: 620px;
		padding: 18px;
	}

	.selector-modal-content {
		width: 88%;
		max-height: 620px;
		padding: 18px;
	}

	.modal-title {
		display: flex;
		font-size: 18px;
		font-weight: bold;
		color: #24323a;
		margin-bottom: 12px;
	}

	.selector-body {
		height: 420px;
		max-height: 420px;
		margin-bottom: 12px;
		padding-right: 8px;
	}

	.modal-body {
		padding: 0;
	}

	.selector-item {
		position: relative;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		height: 52px;
		padding: 0 40px 0 12px;
		border-width: 1px;
		border-style: solid;
		border-color: transparent;
		border-radius: 16px;
		margin-bottom: 8px;
		background-color: #fffdf9;
		box-sizing: border-box;
	}

	.selector-item.selected {
		background-color: #e8f4f2;
		border-color: #d7ece8;
	}

	.selector-left {
		flex-direction: row;
		align-items: center;
		flex: 1;
		min-width: 0;
	}

	.selector-color {
		width: 16px;
		height: 16px;
		border-radius: 8px;
		margin-right: 10px;
	}

	.selector-name {
		font-size: 14px;
		color: #24323a;
		flex: 1;
		lines: 1;
		text-overflow: ellipsis;
	}

	.selector-check-wrap {
		position: absolute;
		right: 10px;
		top: 0;
		bottom: 0;
		width: 24px;
		justify-content: center;
		align-items: center;
	}

	.selector-check {
		width: 24px;
		font-size: 18px;
		color: #1f7a72;
		text-align: center;
		opacity: 0;
	}

	.selector-check.visible {
		opacity: 1;
	}

	.modal-footer {
		flex-direction: row;
		margin-top: 4px;
	}

	.cancel-btn {
		flex: 1;
		height: 44px;
		line-height: 44px;
		border-radius: 22px;
		font-size: 15px;
		background-color: #f2ebe2;
		color: #4d5b67;
		margin-right: 10px;
	}

	.confirm-btn {
		flex: 1;
		height: 44px;
		line-height: 44px;
		border-radius: 22px;
		font-size: 15px;
		background-color: #1f7a72;
		color: #fff;
		margin-left: 10px;
	}

	.single-btn {
		margin-left: 0;
	}

	.color-options {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.color-option {
		width: 36px;
		height: 36px;
		border-radius: 18px;
		margin-right: 10px;
		margin-bottom: 10px;
		justify-content: center;
		align-items: center;
	}

	.color-option.selected {
		box-shadow: 0 0 0 2px #fffaf3, 0 0 0 4px #1f7a72;
	}

	.color-check-icon {
		font-size: 18px;
		color: #fff;
		font-weight: bold;
	}
</style>
