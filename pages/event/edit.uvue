<template>
	<scroll-view scroll-y class="container">
		<view class="form">
			<!-- 事件名称 -->
			<view class="form-item">
				<text class="label">事件名称 *</text>
				<input class="input" v-model="eventName" placeholder="请输入事件名称" />
			</view>

			<!-- 标签选择 -->
			<view class="form-item">
				<text class="label">选择标签</text>
				<view class="tag-selector" @click="showLabelModal">
					<view class="selected-tags">
						<text 
							class="tag" 
							v-for="labelId in selectedLabelIds" 
							:key="labelId"
							:style="{ backgroundColor: getLabelColor(labelId) }"
						>
							{{getLabelName(labelId)}}
						</text>
						<text class="placeholder" v-if="selectedLabelIds.length === 0">请选择标签</text>
					</view>
					<text class="arrow">▼</text>
				</view>
			</view>

			<!-- 重复方式选择 -->
			<view class="form-item">
				<text class="label">重复方式</text>
				<radio-group @change="onRepeatTypeChange">
					<label class="radio-item">
						<radio value="interval" :checked="repeatType === 'interval'" />
						<text class="radio-text">按间隔天数</text>
					</label>
					<label class="radio-item">
						<radio value="date" :checked="repeatType === 'date'" />
						<text class="radio-text">自定义下次完成时间</text>
					</label>
					<label class="radio-item">
						<radio value="single" :checked="repeatType === 'single'" />
						<text class="radio-text">不重复</text>
					</label>
				</radio-group>
			</view>

			<!-- 间隔天数 -->
			<view class="form-item" v-if="repeatType === 'interval'">
				<text class="label">间隔天数</text>
				<input 
					class="input" 
					type="number" 
					v-model="intervalDays" 
					placeholder="0 表示明天，1 表示后天" 
				/>
				<text class="field-tip">按“中间空几天”计算：0 表示明天再次需要完成。</text>
			</view>

			<!-- 下次完成时间 -->
			<view class="form-item" v-if="repeatType === 'date'">
				<text class="label">下次完成时间</text>
				<picker mode="date" :value="nextDueDate" @change="onDateChange">
					<view class="picker">
						<text>{{nextDueDate.length > 0 ? nextDueDate : '请选择日期'}}</text>
					</view>
				</picker>
			</view>

			<!-- 备注 -->
			<view class="form-item">
				<text class="label">备注</text>
				<textarea class="textarea" v-model="remark" placeholder="请输入备注（可选）" />
			</view>

			<!-- 操作按钮 -->
			<view class="action-buttons">
				<button class="terminate-btn" @click="terminateEvent">终止事件</button>
				<button class="save-btn" @click="saveEvent">保存</button>
			</view>
		</view>

		<!-- 标签选择弹窗 -->
		<view class="modal selector-modal" v-if="showLabelSelector" @click="hideLabelModal">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">选择标签</text>
				</view>
				<scroll-view scroll-y class="modal-body selector-body">
					<view class="label-list">
						<view 
							class="label-item" 
							v-for="label in labels" 
							:key="label.id"
							:class="{ 'selected': selectedLabelIds.includes(label.id) }"
							@click.stop="toggleLabel(label.id)"
						>
							<view class="label-info">
								<view class="label-color" :style="{ backgroundColor: label.color }"></view>
								<text class="label-name">{{label.name}}</text>
							</view>
							<view class="label-check-wrap">
								<text class="label-check" :class="{ visible: selectedLabelIds.includes(label.id) }">✓</text>
							</view>
						</view>
					</view>
				</scroll-view>
				<view class="modal-footer">
					<button class="add-label-btn" @click.stop="showAddLabel">新增标签</button>
					<button class="confirm-btn" @click.stop="confirmLabels">确定</button>
				</view>
			</view>
		</view>

		<!-- 新增标签弹窗 -->
		<view class="modal add-label-modal" v-if="showAddLabelModal" @click="hideAddLabelModal">
			<view class="modal-content" @click.stop>
				<view class="modal-header">
					<text class="modal-title">新增标签</text>
				</view>
				<view class="modal-body">
					<view class="form-item">
						<text class="label">标签名称</text>
						<input class="input" v-model="newLabelName" placeholder="请输入标签名称" confirm-type="done" @input="clearNewLabelError" @confirm="addNewLabel" />
						<text class="error-tip" v-if="newLabelError">{{newLabelError}}</text>
					</view>
					<view class="form-item">
						<text class="label">标签颜色</text>
						<view class="color-options">
							<view 
								class="color-option" 
								v-for="color in colorOptions" 
								:key="color"
								:class="{ 'selected': newLabelColor === color }"
								:style="{ backgroundColor: color }"
								@click.stop="newLabelColor = color"
							>
								<text v-if="newLabelColor === color" class="check-icon">✓</text>
							</view>
						</view>
					</view>
				</view>
				<view class="modal-footer">
					<button class="cancel-btn" @click.stop="hideAddLabelModal">取消</button>
					<button class="confirm-btn" @click.stop="addNewLabel">确定</button>
				</view>
			</view>
		</view>
	</scroll-view>
</template>

<script setup lang="uts">
	import { EventManager } from '@/utils/eventManager.uts'
	import { LabelManager } from '@/utils/labelManager.uts'
	import { Event, Label } from '@/utils/storage.uts'

	// 响应式数据
	const eventId = ref(0)
	const currentEvent = ref<Event | null>(null)
	const eventName = ref('')
	const selectedLabelIds = ref<number[]>([])
	const labels = ref<Label[]>([])
	const repeatType = ref<'interval' | 'date' | 'single'>('interval')
	const intervalDays = ref('')
	const nextDueDate = ref('')
	const remark = ref('')
	const showLabelSelector = ref(false)
	const showAddLabelModal = ref(false)
	const shouldRestoreLabelSelector = ref(false)
	const newLabelName = ref('')
	const newLabelError = ref('')
	const newLabelColor = ref('#007AFF')

	// 预设颜色选项
	const colorOptions = [
		'#007AFF', // 蓝色
		'#FF3B30', // 红色
		'#FF9500', // 橙色
		'#FFCC00', // 黄色
		'#4CD964', // 绿色
		'#5AC8FA', // 浅蓝
		'#5856D6', // 紫色
		'#FF2D55', // 粉色
		'#8E8E93', // 灰色
		'#34C759'  // 深绿
	]

	const getDetailObject = (e: UTSJSONObject): UTSJSONObject | null => {
		const detail = e['detail']
		return detail != null ? detail as UTSJSONObject : null
	}

	const getDetailStringValue = (e: UTSJSONObject, key: string): string => {
		const detail = getDetailObject(e)
		if (detail == null) return ''
		const value = detail[key]
		return value != null ? `${value}` : ''
	}

	const getOptionString = (options: UTSJSONObject, key: string): string => {
		const value = options[key]
		return value != null ? `${value}` : ''
	}

	// 格式化日期
	const formatDate = (timestamp: number): string => {
		const date = new Date(timestamp)
		const year = date.getFullYear()
		const month = `${date.getMonth() + 1}`.padStart(2, '0')
		const day = `${date.getDate()}`.padStart(2, '0')
		return `${year}-${month}-${day}`
	}

	// 加载事件数据
	const loadEventData = () => {
		const event = EventManager.getEventById(eventId.value)
		if (event == null) {
			uni.showToast({
				title: '事件不存在',
				icon: 'none'
			})
			setTimeout(() => {
				uni.navigateBack()
			}, 1500)
			return
		}

		currentEvent.value = event
		eventName.value = event.name
		selectedLabelIds.value = event.labelIdList
			.split(',')
			.map(id => parseInt(id))
			.filter(id => !Number.isNaN(id))
		remark.value = event.remark

		if (event.nextDueDate > 0) {
			repeatType.value = 'date'
			nextDueDate.value = formatDate(event.nextDueDate)
		} else if (event.intervalDays >= 0) {
			repeatType.value = 'interval'
			intervalDays.value = `${event.intervalDays}`
		} else {
			repeatType.value = 'single'
		}
	}

	// 加载标签列表
	const loadLabels = () => {
		labels.value = LabelManager.getSortedLabels()
	}

	// 切换标签选择
	const toggleLabel = (labelId: number) => {
		const index = selectedLabelIds.value.indexOf(labelId)
		if (index > -1) {
			selectedLabelIds.value.splice(index, 1)
		} else {
			selectedLabelIds.value.push(labelId)
		}
	}

	// 显示标签选择弹窗
	const showLabelModal = () => {
		showLabelSelector.value = true
	}

	// 隐藏标签选择弹窗
	const hideLabelModal = () => {
		showLabelSelector.value = false
	}

	// 确认标签选择
	const confirmLabels = () => {
		hideLabelModal()
	}

	// 显示新增标签弹窗
	const showAddLabel = () => {
		newLabelName.value = ''
		newLabelError.value = ''
		newLabelColor.value = '#007AFF'
		shouldRestoreLabelSelector.value = showLabelSelector.value
		showLabelSelector.value = false
		showAddLabelModal.value = true
	}

	const closeAddLabelModal = (restoreSelector: boolean) => {
		showAddLabelModal.value = false
		newLabelError.value = ''
		if (restoreSelector && shouldRestoreLabelSelector.value) {
			showLabelSelector.value = true
		}
		shouldRestoreLabelSelector.value = false
	}

	const clearNewLabelError = () => {
		if (newLabelError.value.length > 0) {
			newLabelError.value = ''
		}
	}

	// 隐藏新增标签弹窗
	const hideAddLabelModal = () => {
		closeAddLabelModal(true)
	}

	// 新增标签
	const addNewLabel = () => {
		const createdName = newLabelName.value.trim()
		if (createdName.length === 0) {
			newLabelError.value = '请输入标签名称'
			uni.showToast({
				title: '请输入标签名称',
				icon: 'none'
			})
			return
		}

		const existingLabel = LabelManager.getLabelByName(createdName)
		if (existingLabel != null) {
			if (selectedLabelIds.value.includes(existingLabel.id) == false) {
				selectedLabelIds.value.push(existingLabel.id)
			}
			newLabelError.value = '已存在同名标签，已为你选中'
			uni.showToast({
				title: '标签已存在，已选中',
				icon: 'none'
			})
			return
		}

		const success = LabelManager.addLabel(createdName, newLabelColor.value)
		if (success == true) {
			newLabelName.value = ''
			newLabelError.value = ''
			newLabelColor.value = '#007AFF'
			uni.showToast({
				title: '添加成功',
				icon: 'success'
			})
			loadLabels()
			const created = labels.value.find(item => item.name === createdName)
			if (created != null && selectedLabelIds.value.includes(created.id) == false) {
				selectedLabelIds.value.push(created.id)
			}
			closeAddLabelModal(true)
		} else {
			newLabelError.value = '添加失败，请稍后再试'
			uni.showToast({
				title: '添加失败',
				icon: 'none'
			})
		}
	}

	// 获取标签名称
	const getLabelName = (labelId: number): string => {
		const label = labels.value.find(l => l.id === labelId)
		return label != null ? label.name : ''
	}

	// 获取标签颜色
	const getLabelColor = (labelId: number): string => {
		const label = labels.value.find(l => l.id === labelId)
		return label != null ? label.color : '#007AFF'
	}

	// 重复方式改变
	const onRepeatTypeChange = (e: UTSJSONObject) => {
		const value = getDetailStringValue(e, 'value')
		if (value === 'date' || value === 'single') {
			repeatType.value = value
			return
		}
		repeatType.value = 'interval'
	}

	// 日期改变
	const onDateChange = (e: UTSJSONObject) => {
		nextDueDate.value = getDetailStringValue(e, 'value')
	}

	// 保存事件
	const saveEvent = () => {
		if (eventName.value.trim().length === 0) {
			uni.showToast({
				title: '请输入事件名称',
				icon: 'none'
			})
			return
		}

		if (repeatType.value === 'interval' && intervalDays.value.length === 0) {
			uni.showToast({
				title: '请输入间隔天数',
				icon: 'none'
			})
			return
		}

		if (repeatType.value === 'interval') {
			const interval = parseInt(intervalDays.value)
			if (Number.isNaN(interval) || interval < 0) {
				uni.showToast({
					title: '间隔天数不能小于 0',
					icon: 'none'
				})
				return
			}
		}

		if (repeatType.value === 'date' && nextDueDate.value.length === 0) {
			uni.showToast({
				title: '请选择下次完成时间',
				icon: 'none'
			})
			return
		}

		if (currentEvent.value == null) {
			uni.showToast({
				title: '事件不存在',
				icon: 'none'
			})
			return
		}

		const event: Event = {
			id: eventId.value,
			name: eventName.value,
			labelIdList: selectedLabelIds.value.join(','),
			intervalDays: repeatType.value === 'interval' ? parseInt(intervalDays.value) : (repeatType.value === 'single' ? -1 : 0),
			nextDueDate: repeatType.value === 'date' ? new Date(nextDueDate.value).getTime() : 0,
			remark: remark.value,
			isTerminated: currentEvent.value.isTerminated,
			terminatedAt: currentEvent.value.terminatedAt,
			createTime: currentEvent.value.createTime,
			updateTime: currentEvent.value.updateTime
		}

		const success = EventManager.updateEvent(event)
		if (success == true) {
			uni.showToast({
				title: '保存成功',
				icon: 'success'
			})
			setTimeout(() => {
				uni.navigateBack()
			}, 1500)
		} else {
			uni.showToast({
				title: '保存失败',
				icon: 'none'
			})
		}
	}

	// 终止事件
	const terminateEvent = () => {
		uni.showModal({
			title: '确认终止',
			content: '确定要终止这个事件吗？终止后事件将不再显示在列表中。',
			success: (res) => {
				if (res.confirm == true) {
					const success = EventManager.terminateEvent(eventId.value)
					if (success == true) {
						uni.showToast({
							title: '已终止',
							icon: 'success'
						})
						setTimeout(() => {
							uni.navigateBack()
						}, 1500)
					} else {
						uni.showToast({
							title: '终止失败',
							icon: 'none'
						})
					}
				}
			}
		})
	}

	// 页面加载时获取数据
	onLoad((options: UTSJSONObject) => {
		const id = getOptionString(options, 'id')
		if (id.length > 0) {
			eventId.value = parseInt(id)
			loadEventData()
			loadLabels()
		} else {
			uni.showToast({
				title: '参数错误',
				icon: 'none'
			})
			setTimeout(() => {
				uni.navigateBack()
			}, 1500)
		}
	})
</script>

<style>
	.container {
		padding: 15px;
		background-color: #f4efe7;
		flex: 1;
	}

	.form {
		background-color: #fffaf3;
		border-radius: 24px;
		padding: 18px;
		border-width: 1px;
		border-style: solid;
		border-color: #eadfd2;
		box-shadow: 0 12px 28px rgba(36, 50, 58, 0.06);
	}

	.form-item {
		margin-bottom: 20px;
	}

	.label {
		display: flex;
		font-size: 14px;
		color: #4e5b67;
		margin-bottom: 10px;
		font-weight: 500;
	}

	.input {
		width: 100%;
		height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 0 15px;
		font-size: 14px;
		color: #24323a;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.tags-container {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.tag-selector {
		height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 8px 12px;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
		box-sizing: border-box;
		overflow: hidden;
	}

	.selected-tags {
		flex: 1;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: center;
		height: 26px;
		max-height: 26px;
		overflow: hidden;
	}

	.tag {
		font-size: 12px;
		color: #fff;
		height: 22px;
		line-height: 22px;
		padding: 0 8px;
		border-radius: 10px;
		margin-right: 5px;
		margin-bottom: 0;
	}

	.placeholder {
		font-size: 14px;
		color: #98a2ad;
	}

	.arrow {
		margin-left: 10px;
		font-size: 12px;
		color: #8792a1;
	}

	.textarea {
		width: 100%;
		min-height: 100px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 10px 15px;
		font-size: 14px;
		color: #24323a;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.radio-item {
		flex-direction: row;
		align-items: center;
		margin-bottom: 10px;
	}

	.radio-text {
		margin-left: 8px;
		font-size: 14px;
	}

	.picker {
		height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 0 15px;
		justify-content: center;
		font-size: 14px;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.field-tip {
		font-size: 12px;
		line-height: 1.5;
		color: #8792a1;
		margin-top: 8px;
	}

	.error-tip {
		font-size: 12px;
		line-height: 1.5;
		color: #e07a5f;
		margin-top: 6px;
	}

	.action-buttons {
		flex-direction: row;
		justify-content: space-between;
		margin-top: 20px;
	}

	.save-btn {
		flex: 1;
		height: 44px;
		line-height: 44px;
		border-radius: 22px;
		font-size: 16px;
	}

	.terminate-btn {
		flex: 1;
		height: 44px;
		line-height: 44px;
		border-radius: 22px;
		font-size: 16px;
	}

	.save-btn {
		background: linear-gradient(135deg, #1f7a72, #2a9d8f);
		color: #fff;
		margin-left: 10px;
		box-shadow: 0 14px 24px rgba(31, 122, 114, 0.18);
	}

	.terminate-btn {
		background-color: #e07a5f;
		color: #fff;
		margin-right: 10px;
		box-shadow: 0 12px 20px rgba(224, 122, 95, 0.16);
	}

	/* 弹窗样式 */
	.modal {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		justify-content: center;
		align-items: center;
		z-index: 1000;
	}

	.selector-modal {
		z-index: 1000;
	}

	.add-label-modal {
		z-index: 1010;
	}

	.modal-content {
		background-color: #fffaf3;
		border-radius: 22px;
		width: 85%;
		max-height: 560px;
	}

	.modal-header {
		padding: 15px;
		border-bottom: 1px solid #f0f0f0;
	}

	.modal-title {
		font-size: 18px;
		font-weight: bold;
		color: #24323a;
		text-align: center;
	}

	.modal-body {
		padding: 15px;
		max-height: 400px;
	}

	.selector-body {
		height: 420px;
		max-height: 420px;
	}

	.label-list {
		padding: 0;
	}

	.label-item {
		position: relative;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		height: 52px;
		padding: 0 44px 0 12px;
		border-width: 1px;
		border-style: solid;
		border-color: transparent;
		border-radius: 16px;
		margin-bottom: 8px;
		background-color: #fffdf9;
		box-sizing: border-box;
	}

	.label-item.selected {
		background-color: #e8f4f2;
		border-color: #d7ece8;
	}

	.label-info {
		flex-direction: row;
		align-items: center;
		flex: 1;
		min-width: 0;
	}

	.label-color {
		width: 20px;
		height: 20px;
		border-radius: 10px;
		margin-right: 10px;
	}

	.label-name {
		font-size: 16px;
		color: #24323a;
		flex: 1;
		lines: 1;
		text-overflow: ellipsis;
	}

	.check-icon {
		font-size: 20px;
		color: #1f7a72;
		font-weight: bold;
	}

	.label-check-wrap {
		position: absolute;
		right: 10px;
		top: 0;
		bottom: 0;
		width: 24px;
		justify-content: center;
