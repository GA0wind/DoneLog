	.list-card,
	.modal-content {
		background-color: #fffaf3;
		border-radius: 24px;
		border-width: 1px;
		border-style: solid;
		border-color: #eadfd2;
		box-shadow: 0 12px 28px rgba(36, 50, 58, 0.05);
	}

	.summary-card {
		flex-direction: row;
		flex-wrap: wrap;
		padding: 16px;
		margin-bottom: 14px;
	}

	.summary-item {
		flex: 1;
		min-width: 30%;
		padding: 10px;
	}

	.summary-value {
		display: block;
		font-size: 18px;
		font-weight: bold;
		color: #24323a;
		margin-bottom: 6px;
	}

	.summary-label {
		font-size: 12px;
		color: #7b8791;
	}

