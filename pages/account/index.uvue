		background: linear-gradient(135deg, #1f7a72, #2a9d8f);
		justify-content: center;
		align-items: center;
		box-shadow: 0 16px 28px rgba(31, 122, 114, 0.22);
	}

	.add-icon {
		font-size: 32px;
		color: #fff;
	}

	.modal {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.36);
		justify-content: center;
		align-items: center;
		padding: 16px;
	}

	.modal-content {
		width: 88%;
		max-height: 80vh;
		padding: 18px;
	}

	.selector-modal-content {
		width: 88%;
		max-height: 78vh;
		padding: 18px;
	}

	.modal-title {
		display: block;
		font-size: 18px;
		font-weight: bold;
		color: #24323a;
		margin-bottom: 12px;
	}

	.form-item {
		margin-bottom: 14px;
	}

	.label {
		display: block;
		font-size: 14px;
		color: #4d5b67;
		margin-bottom: 8px;
	}

	.radio-chip {
		flex: 1;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		padding: 10px 14px;
		background-color: #fffdf9;
		border-radius: 999px;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.type-group {
		flex-direction: row;
		align-items: center;
	}

	.type-group .radio-chip:first-child {
		margin-right: 10px;
	}

	.radio-chip.active {
		background-color: #f6eee4;
		border-color: #dfc5b8;
	}

	.input,
	.picker,
	.textarea {
		background-color: #fffdf9;
		border-radius: 16px;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
		padding: 0 14px;
	}

	.input,
	.picker {
		height: 44px;
		justify-content: center;
	}

	.textarea {
		min-height: 90px;
		padding-top: 10px;
	}

	.color-options {
		flex-direction: row;
		flex-wrap: wrap;
	}

	.color-option {
		width: 34px;
		height: 34px;
		border-radius: 17px;
		margin-right: 10px;
		margin-bottom: 10px;
		justify-content: center;
		align-items: center;
	}

	.color-option.selected {
		box-shadow: 0 0 0 2px #fffaf3, 0 0 0 4px #1f7a72;
	}

	.color-check {
		color: #fff;
		font-size: 16px;
	}

	.selector-body {
		height: 420px;
		margin-bottom: 12px;
		padding-right: 8px;
	}

	.selector-item {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		height: 52px;
		padding: 0 12px;
		border-width: 1px;
		border-style: solid;
		border-color: transparent;
		border-radius: 16px;
		margin-bottom: 8px;
		background-color: #fffdf9;
	}

	.selector-item:active {
		background-color: #f7f1e8;
	}

	.selector-item.selected {
		background-color: #e8f4f2;
		border-color: #d7ece8;
	}

	.selector-left {
		flex-direction: row;
		align-items: center;
	}

	.selector-color {
		width: 16px;
		height: 16px;
		border-radius: 8px;
		margin-right: 10px;
	}

	.selector-name {
		font-size: 14px;
		color: #24323a;
	}

	.selector-check {
		width: 28px;
		font-size: 18px;
		color: #1f7a72;
		text-align: center;
		margin-right: 2px;
		flex-shrink: 0;
		opacity: 0;
	}

	.selector-check.visible {
		opacity: 1;
	}

	.modal-footer {
		flex-direction: row;
		margin-top: 4px;
	}

	.cancel-btn,
	.confirm-btn {
		flex: 1;
		height: 44px;
		line-height: 44px;
		border-radius: 22px;
		font-size: 15px;
	}

	.cancel-btn {
		background-color: #f0e7dc;
		color: #4d5b67;
		margin-right: 10px;
	}

	.confirm-btn {
		background-color: #1f7a72;
		color: #fff;
		margin-left: 10px;
	}
</style>
