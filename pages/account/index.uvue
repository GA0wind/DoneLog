		overflow: hidden;
	}

	.entry-item {
		flex-direction: row;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		padding: 16px;
		border-bottom-width: 1px;
		border-bottom-style: solid;
		border-bottom-color: #f1e7dd;
	}

	.entry-item:last-child {
		border-bottom-width: 0;
	}

	.entry-left,
	.entry-right {
		flex-direction: row;
		align-items: center;
	}

	.entry-left {
		flex: 1;
		min-width: 0;
		padding-right: 10px;
	}

	.entry-right {
		margin-top: 8px;
		margin-left: auto;
	}

	.entry-info {
		margin-left: 10px;
		flex: 1;
		min-width: 0;
	}

	.entry-icon {
		width: 34px;
		height: 34px;
		border-radius: 17px;
		justify-content: center;
		align-items: center;
	}

	.entry-icon.expense {
		background-color: #f8ddd3;
	}

	.entry-icon.income {
		background-color: #e8f4f2;
	}

	.entry-icon-text {
		font-size: 12px;
		font-weight: bold;
		color: #24323a;
	}

	.entry-desc {
		display: block;
		font-size: 15px;
		font-weight: 600;
		color: #24323a;
		margin-bottom: 4px;
	}

	.entry-meta {
		font-size: 12px;
		color: #7b8791;
		line-height: 1.5;
	}

	.entry-amount {
		font-size: 15px;
		font-weight: bold;
	}

	.entry-amount.expense {
		color: #c45d42;
	}

	.entry-amount.income {
		color: #1f7a72;
	}

	.delete-btn {
		margin-left: 10px;
		background-color: #e07a5f;
		color: #fff;
		height: 32px;
		line-height: 32px;
		padding: 0 12px;
		border-radius: 999px;
		font-size: 12px;
	}

	.label-row {
		flex-direction: row;
		align-items: flex-start;
	}

	.tag-selector {
		flex: 1;
		margin-right: 10px;
		min-height: 44px;
		background-color: #fffdf9;
		border-radius: 16px;
		padding: 8px 12px;
		border-width: 1px;
		border-style: solid;
		border-color: #eee2d7;
	}

	.selected-tags {
		flex-direction: row;
		flex-wrap: wrap;
		max-height: 52px;
		overflow: hidden;
	}

	.tag {
		font-size: 12px;
		color: #fff;
		padding: 4px 10px;
		border-radius: 999px;
		margin-right: 6px;
		margin-bottom: 6px;
	}

	.placeholder {
		font-size: 14px;
		color: #98a2ad;
	}

	.mini-add-btn {
		height: 44px;
		line-height: 44px;
		padding: 0 14px;
		border-radius: 16px;
		background-color: #f2ebe2;
		color: #4d5b67;
		font-size: 13px;
		flex-shrink: 0;
	}

	.empty-tip {
		padding: 28px;
		text-align: center;
		color: #8792a1;
	}

	.add-btn {
		position: fixed;
		right: 18px;
		bottom: 90px;
		width: 58px;
		height: 58px;
