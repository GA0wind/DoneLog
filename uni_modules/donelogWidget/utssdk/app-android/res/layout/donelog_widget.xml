<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:padding="12dp"
	android:background="@android:color/white">

	<TextView
		android:id="@+id/widget_title"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:text="DoneLog 今日事件"
		android:textColor="#24323A"
		android:textSize="16sp"
		android:textStyle="bold" />

	<TextView
		android:id="@+id/widget_subtitle"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="4dp"
		android:text="点按条目进入完成流程"
		android:textColor="#72808D"
		android:textSize="12sp" />

	<LinearLayout
		android:id="@+id/row_1"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="10dp"
		android:orientation="horizontal"
		android:gravity="center_vertical">
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:orientation="vertical">
			<TextView
				android:id="@+id/row_1_name"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textColor="#24323A"
				android:textSize="14sp"
				android:textStyle="bold" />
			<TextView
				android:id="@+id/row_1_status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:textColor="#72808D"
				android:textSize="12sp" />
		</LinearLayout>
		<TextView
			android:id="@+id/row_1_action"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:paddingLeft="10dp"
			android:paddingTop="6dp"
			android:paddingRight="10dp"
			android:paddingBottom="6dp"
			android:text="完成"
			android:textColor="#FFFFFF"
			android:textSize="12sp"
			android:background="#1F7A72" />
	</LinearLayout>

	<LinearLayout
		android:id="@+id/row_2"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:orientation="horizontal"
		android:gravity="center_vertical">
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:orientation="vertical">
			<TextView
				android:id="@+id/row_2_name"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textColor="#24323A"
				android:textSize="14sp"
				android:textStyle="bold" />
			<TextView
				android:id="@+id/row_2_status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:textColor="#72808D"
				android:textSize="12sp" />
		</LinearLayout>
		<TextView
			android:id="@+id/row_2_action"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:paddingLeft="10dp"
			android:paddingTop="6dp"
			android:paddingRight="10dp"
			android:paddingBottom="6dp"
			android:text="完成"
			android:textColor="#FFFFFF"
			android:textSize="12sp"
			android:background="#1F7A72" />
	</LinearLayout>

	<LinearLayout
		android:id="@+id/row_3"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:orientation="horizontal"
		android:gravity="center_vertical">
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:orientation="vertical">
			<TextView
				android:id="@+id/row_3_name"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textColor="#24323A"
				android:textSize="14sp"
				android:textStyle="bold" />
			<TextView
				android:id="@+id/row_3_status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:textColor="#72808D"
				android:textSize="12sp" />
		</LinearLayout>
		<TextView
			android:id="@+id/row_3_action"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:paddingLeft="10dp"
			android:paddingTop="6dp"
			android:paddingRight="10dp"
			android:paddingBottom="6dp"
			android:text="完成"
			android:textColor="#FFFFFF"
			android:textSize="12sp"
			android:background="#1F7A72" />
	</LinearLayout>

	<LinearLayout
		android:id="@+id/row_4"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:orientation="horizontal"
		android:gravity="center_vertical">
		<LinearLayout
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:orientation="vertical">
			<TextView
				android:id="@+id/row_4_name"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textColor="#24323A"
				android:textSize="14sp"
				android:textStyle="bold" />
			<TextView
				android:id="@+id/row_4_status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:textColor="#72808D"
				android:textSize="12sp" />
		</LinearLayout>
		<TextView
			android:id="@+id/row_4_action"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:paddingLeft="10dp"
			android:paddingTop="6dp"
			android:paddingRight="10dp"
			android:paddingBottom="6dp"
			android:text="完成"
			android:textColor="#FFFFFF"
			android:textSize="12sp"
			android:background="#1F7A72" />
	</LinearLayout>
</LinearLayout>
